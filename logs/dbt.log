  create temporary table "fct_orders_incremental__dbt_tmp150725116862"
  
  
    as
  
  (
    

with orders as (
    select * from "dbt_practice"."staging"."stg_orders"
),

customers as (
    select * from "dbt_practice"."staging"."stg_customers"
),

final as (
    select
        o.order_id,
        o.customer_id,
        c.full_name,
        o.amount_dollars,
        o.status,
        o.ordered_at
    from orders o
    left join customers c using (customer_id)

    
    -- Chỉ load các đơn hàng mới hơn giá trị lớn nhất đang có trong bảng
    where o.ordered_at > (select max(ordered_at) from "dbt_practice"."marts"."fct_orders_incremental")
    
)

select * from final
  );
  
  
