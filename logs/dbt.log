  create  table "dbt_practice"."marts"."dim_customer_profile_scd2__dbt_tmp"
  
  
    as
  
  (
    



with source_data as (
    select
        *,
        md5(
            concat_ws(
                '||',
                coalesce(cast(full_name as text), '__dbt_null__'), coalesce(cast(email as text), '__dbt_null__'), coalesce(cast(status as text), '__dbt_null__')
            )
        ) as scd2_change_hash,
        lag(
            md5(
                concat_ws(
                    '||',
                    coalesce(cast(full_name as text), '__dbt_null__'), coalesce(cast(email as text), '__dbt_null__'), coalesce(cast(status as text), '__dbt_null__')
                )
            )
        ) over (
            partition by customer_id
            order by updated_at, customer_id
        ) as previous_scd2_change_hash,
        lead(updated_at) over (
            partition by customer_id
            order by updated_at, customer_id
        ) as next_dbt_valid_from
    from "dbt_practice"."staging"."stg_customer_profile_history"
),

change_rows as (
    select
        *
    from source_data
    where previous_scd2_change_hash is null
       or previous_scd2_change_hash <> scd2_change_hash
),

final as (
    select
        *,
        coalesce(next_dbt_valid_from, timestamp '9999-12-31 23:59:59') as dbt_valid_to,
        case when next_dbt_valid_from is null then true else false end as is_current
    from change_rows
)

select
    *
from final
order by customer_id, dbt_valid_from


  );
  
